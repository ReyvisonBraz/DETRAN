# Chave da API do 2Captcha (obrigatorio para resolver os CAPTCHAs)
TWOCAPTCHA_API_KEY=

# Origens permitidas do frontend (CORS), separadas por virgula
CORS_ORIGINS=http://localhost:3000,https://seu-painel.vercel.app

# Onde guardar PDFs temporariamente antes do upload (padrao: backend/storage)
STORAGE_DIR=

# Jobs processados em paralelo
MAX_WORKERS=2

# ── Firebase Storage (PDFs persistentes por 5 dias) ─────────────────────────
# Obtenha em: Firebase Console → Configurações do Projeto → Contas de serviço
# → Gerar nova chave privada (JSON). Copie os campos abaixo do JSON gerado.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PRIVATE_KEY_ID=
# Bucket do Firebase Storage: geralmente "<project-id>.firebasestorage.app"
FIREBASE_STORAGE_BUCKET=
