rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Usuários ──────────────────────────────────────────────────────────────
    // Cada usuário só lê/escreve o próprio documento
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Subcoleção de histórico de consultas
      match /consultas/{jobId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Feedbacks ─────────────────────────────────────────────────────────────
    // ID do documento = "{uid}_{jobId}" — usuário só escreve/lê o próprio
    match /feedbacks/{feedbackId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && feedbackId.matches(request.auth.uid + '_.*');

      // Não permite update/delete (feedback é imutável)
      allow update, delete: if false;
    }

    // ── Estornos ──────────────────────────────────────────────────────────────
    // ID do documento = "{uid}_{jobId}" — apenas o próprio usuário cria
    match /refunds/{refundId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && refundId.matches(request.auth.uid + '_.*');

      // Não permite update/delete (estorno é imutável)
      allow update, delete: if false;
    }

    // Nenhum outro documento é acessível
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
