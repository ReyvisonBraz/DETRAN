# =============================================================================
# VAULT — Detran-PA Consultas (.env.secrets.example)
# =============================================================================
# COPIE este arquivo para .env.secrets e preencha os valores:
#   copy .env.secrets.example .env.secrets
#   Depois execute: powershell -ExecutionPolicy Bypass -File scripts/setup-env.ps1
# =============================================================================

# ── 2Captcha (obrigatorio para RENACH / Image CAPTCHA) ───────────────────────
# Obtenha em https://2captcha.com/
TWOCAPTCHA_API_KEY=

# ── Firebase Admin (conta de servico para o backend) ──────────────────────────
# Obtenha em: Firebase Console > Configuracoes do projeto > Contas de servico
# > Gerar nova chave privada (baixe o JSON e copie os campos)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY_ID=
# Cole a chave inteira entre aspas duplas, mantendo os \n literais:
# Ex: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# ── Firebase Web (valores publicos do app web, safe no frontend) ──────────────
# Obtenha em: Firebase Console > Configuracoes do projeto > Seus apps > Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Backend ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
MAX_WORKERS=2

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000