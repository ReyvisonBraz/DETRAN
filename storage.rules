rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // PDFs gerados pelo backend. Leitura via URL assinada; escrita só pela service account.
    match /pdfs/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Nenhum outro caminho é acessível
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
