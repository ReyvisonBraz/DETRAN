# Chave da API do 2Captcha (obrigatorio para resolver os CAPTCHAs)
TWOCAPTCHA_API_KEY=

# Origens permitidas do frontend (CORS), separadas por virgula
CORS_ORIGINS=http://localhost:3000,https://seu-painel.vercel.app

# Onde guardar PDFs/boletos gerados (padrao: backend/storage)
STORAGE_DIR=

# Jobs processados em paralelo
MAX_WORKERS=2
